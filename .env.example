# ═══════════════════════════════════════════════════════
#  ViralIntel — Archive Search Platform
#  NAB 2026 / TwelveLabs × AWS Bedrock Hackathon
# ═══════════════════════════════════════════════════════

# ── AWS Bedrock (PRIMARY — use for hackathon) ─────────
# TwelveLabs Marengo runs via AWS Bedrock with provided credits
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SESSION_TOKEN=your_session_token_if_using_temp_creds
AWS_REGION=us-east-1

# ── TwelveLabs Direct API (FALLBACK) ──────────────────
# Used only if AWS Bedrock credentials are not set
TWELVELABS_API_KEY=your_twelvelabs_key

# ── Anthropic Opus 4.6 (REQUIRED) ────────────────────
ANTHROPIC_API_KEY=your_anthropic_key

# ── Optional revenue / integration keys ──────────────
ZEROCLICK_API_KEY=
YOUTUBE_API_KEY=
CIRCLE_API_KEY=
CIRCLE_WALLET_ID=
CIRCLE_ENTITY_SECRET=
CIRCLE_ENVIRONMENT=testnet
X402_ENFORCE_PAYMENT=false
LTX_API_KEY=
TRACKIT_API_KEY=
TRACKIT_PARTNER_ID=
TRACKIT_MAM_ENDPOINT=

# ── Ad networks (disabled by default) ────────────────
ENABLE_GAM=false
ENABLE_TTD=false

# ── Archive ingestion config ──────────────────────────
TARGET_VIDEOS=500
MIN_VIEWS=1000
TIKTOK_SPLIT=0.0

# Archive category targets (must sum to TARGET_VIDEOS)
SPORTS_COUNT=175
NEWS_COUNT=125
PRODUCTION_COUNT=100
DOCUMENTARY_COUNT=60
ENTERTAINMENT_COUNT=40

# ── Infrastructure (Docker internal — do not change) ──
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=viralpass123
REDIS_URL=redis://redis:6379
